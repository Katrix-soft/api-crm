# ─── Seguridad (JWT Tokens) ───
# Clave para firmar las sesiones. Debe ser una clave larga y segura.
# Podés generar una con: openssl rand -hex 32
KATRIX_SECRET_KEY=reemplaza-con-un-secreto-seguro-de-64-caracteres

# Duración del token en horas antes de expirar
TOKEN_EXPIRE_HOURS=24

# ─── CORS (Orígenes cruzados) ───
# Orígenes permitidos. "*" permite que la app se conecte desde cualquier lado.
KATRIX_CORS_ORIGINS=*

# ─── Puerto de la API ───
PORT=8000
